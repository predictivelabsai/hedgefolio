# ---- Required ----
DB_URL=postgresql://user:password@host:5432/database
XAI_API_KEY=xai-...

# ---- Optional (defaults shown) ----
DB_SCHEMA=hedgefolio
GROK_MODEL=grok-4-fast-reasoning
LLM_PROVIDER=XAI
PORT=5011
LOG_LEVEL=INFO

# Used when hitting SEC EDGAR — SEC asks every automated client to identify
# itself with a real contact address.
SEC_USER_AGENT=Hedgefolio/0.1 (you@example.com)

# ---- Optional: email subscribe ----
POSTMARK_API_KEY=
TO_EMAIL=
FROM_EMAIL=

# ---- Optional: session signing (random-generated if absent) ----
JWT_SECRET=
